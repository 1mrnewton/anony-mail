# ---- Required ----

# Comma-separated list of domains this server accepts mail for.
# An MX record for each domain must point at this server's public IP.
DOMAINS=example.com,mail.example.com

# PostgreSQL connection string.
DATABASE_URL=postgres://anonymail:anonymail@localhost:5432/anonymail

# ---- Networking ----

# SMTP receiver bind address. Port 25 requires root or CAP_NET_BIND_SERVICE.
SMTP_BIND_ADDR=0.0.0.0:25

# HTTP API bind address.
API_BIND_ADDR=0.0.0.0:8080

# Hostname announced in the SMTP banner/EHLO. Defaults to the first domain.
# SMTP_HOSTNAME=mail.example.com

# ---- Mailbox lifecycle ----

# How long a newly created mailbox lives, in seconds (default 1 hour).
DEFAULT_TTL_SECONDS=3600

# How often expired mailboxes are purged, in seconds.
CLEANUP_INTERVAL_SECONDS=300

# ---- SMTP hygiene limits ----

# Largest accepted message in bytes (default 25 MiB).
MAX_MESSAGE_SIZE_BYTES=26214400

# Max recipients per SMTP transaction.
MAX_RECIPIENTS=100

# Max concurrent SMTP connections (server-wide).
MAX_CONNECTIONS=1024

# Idle/session timeout for a single SMTP connection, in seconds.
SMTP_SESSION_TIMEOUT_SECONDS=60

# Max new SMTP connections from a single IP per 60s window.
SMTP_PER_IP_CONNECTIONS_PER_MIN=60

# ---- Optional STARTTLS ----
# Set both to enable STARTTLS on the SMTP listener (PEM files).
# TLS_CERT_PATH=/etc/anony-mail/tls/fullchain.pem
# TLS_KEY_PATH=/etc/anony-mail/tls/privkey.pem

# ---- HTTP ----

# Comma-separated allowed CORS origins, or * for any.
CORS_ALLOWED_ORIGINS=*

# ---- Logging ----
# tracing/env-filter directive.
RUST_LOG=info,anony_mail=debug
